<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Debug-only override: allows cleartext (HTTP) traffic on the LAN so the app can
      reach a local development server, and points to a network security config that
      restricts cleartext to the configured local hostnames/IP ranges only. This file
      is never merged into the release build.
    -->
    <application
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config_debug"
        tools:replace="android:usesCleartextTraffic"
        tools:targetApi="28"
        xmlns:tools="http://schemas.android.com/tools">
    </application>

</manifest>
