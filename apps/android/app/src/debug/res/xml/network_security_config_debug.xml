<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only: the Connection Settings screen lets a developer point the app at any
  host on their local network (hostname or IP), which is normally plain HTTP. This
  config is only referenced from src/debug/AndroidManifest.xml and never ships in
  release builds, where cleartext stays disallowed everywhere.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
