<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      No public HTTPS backend is planned. The API is reachable only over
      Tailscale (MagicDNS), so cleartext HTTP is allowed for that one host
      only — everything else stays blocked by the default in the main
      manifest.
    -->
    <application
        android:networkSecurityConfig="@xml/network_security_config_release"
        android:usesCleartextTraffic="true"
        tools:replace="android:usesCleartextTraffic"
        tools:targetApi="28" />

</manifest>
