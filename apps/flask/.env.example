DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_CONTAINER_NAME=your_postgresql_container_name

APP_SECRET_KEY=replace_with_a_long_random_secret
SESSION_TIMEOUT_MINUTES=5

BACKUP_DIR=backups/database
BACKUP_RETENTION_DAYS=30
ENV_BACKUP_DIR=backups/env
ENV_BACKUP_RETENTION_DAYS=30

INITIAL_ADMIN_USERNAME=your_initial_admin_username
INITIAL_ADMIN_PASSWORD=your_initial_admin_password
DEMO_USERNAME=demo
DEMO_PASSWORD=your_demo_password
ROLE_MANAGER_USERNAME=admin
ROLE_MANAGER_PASSWORD=your_role_manager_password
