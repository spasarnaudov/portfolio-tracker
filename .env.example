# Application environment: development, test, staging, or production.
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Generate a unique value, for example with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Flask server. Use 0.0.0.0 only when the app must be reachable from the LAN.
HOST=127.0.0.1
PORT=5000

# PostgreSQL. DATABASE_URL takes precedence over the individual DB_* settings.
DATABASE_URL=postgresql://portfolio_user:replace-with-password@localhost:5432/portfolio_tracker
DB_NAME=portfolio_tracker
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=portfolio_user
# DB_PASSWORD=replace-with-password

# Authentication and session behavior.
ROLE_MANAGER_USERNAME=admin
SESSION_TIMEOUT_MINUTES=5
# SESSION_COOKIE_NAME=portfolio_tracker_session

# Optional convenience value used by the documented create-user command.
ROLE_MANAGER_PASSWORD=replace-with-a-strong-password

# Backup settings. Relative paths are resolved from the project root by the scripts.
BACKUP_DIR=backups/database
BACKUP_RETENTION_DAYS=30
ENV_BACKUP_DIR=backups/env
ENV_BACKUP_RETENTION_DAYS=30
