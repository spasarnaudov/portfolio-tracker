# Required. Generate a unique value with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Use 0.0.0.0 when the application must be reachable from a mobile device on the LAN.
HOST=0.0.0.0
LOG_LEVEL=INFO

# Required PostgreSQL connection. DB_NAME is also used in backup filenames.
DATABASE_URL=postgresql://portfolio_user:replace-with-password@localhost:5432/portfolio_tracker
DB_NAME=portfolio_tracker

# Optional application overrides. Values below are the built-in defaults.
# APP_ENV=development
# DEBUG=true
# PORT=5000
# ROLE_MANAGER_USERNAME=admin
# SESSION_TIMEOUT_MINUTES=5
# SESSION_COOKIE_NAME=portfolio_tracker_session

# Optional alternative to DATABASE_URL. These are ignored while DATABASE_URL is set.
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=portfolio_user
# DB_PASSWORD=replace-with-password

# Optional backup overrides. These values are already the script defaults.
# BACKUP_DIR=backups/database
# BACKUP_RETENTION_DAYS=30
# ENV_BACKUP_DIR=backups/env
# ENV_BACKUP_RETENTION_DAYS=30
